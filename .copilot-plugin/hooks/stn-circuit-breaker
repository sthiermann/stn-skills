#!/bin/sh
# .copilot-plugin/hooks/stn-circuit-breaker — Copilot CLI wrapper for hooks/stn-circuit-breaker
# Copilot honors `permissionDecision: deny` on preToolUse, so RED circuit breaker
# blocks modifications on Copilot just like on Claude/Cursor.
[ "${STN_SKILLS_HOOKS_DISABLE:-}" = "1" ] && exit 0
[ -n "$BASH_VERSION" ] || exec bash "$0" "$@"
export STN_PLATFORM="copilot"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec "${SCRIPT_DIR}/../../hooks/stn-circuit-breaker" "$@"
