#!/bin/sh
# .copilot-plugin/hooks/stn-state-validator — Copilot CLI wrapper for hooks/stn-state-validator
# Copilot honors `permissionDecision: deny` on preToolUse, so this hook enforces
# pipeline state integrity on Copilot just like on Claude/Cursor.
[ "${STN_SKILLS_HOOKS_DISABLE:-}" = "1" ] && exit 0
[ -n "$BASH_VERSION" ] || exec bash "$0" "$@"
export STN_PLATFORM="copilot"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec "${SCRIPT_DIR}/../../hooks/stn-state-validator" "$@"
