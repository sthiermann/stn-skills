#!/bin/sh
# .copilot-plugin/hooks/stn-session-lock — Copilot CLI wrapper for hooks/stn-session-lock
# Sets platform marker, self-locates, re-execs the main hook under bash.
[ "${STN_SKILLS_HOOKS_DISABLE:-}" = "1" ] && exit 0
[ -n "$BASH_VERSION" ] || exec bash "$0" "$@"
export STN_PLATFORM="copilot"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec "${SCRIPT_DIR}/../../hooks/stn-session-lock" "$@"
