{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CURSOR_PLUGIN_ROOT}/hooks/stn-init\"",
            "async": false,
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "\"${CURSOR_PLUGIN_ROOT}/hooks/stn-session-lock\"",
            "async": false,
            "timeout": 10000
          }
        ]
      }
    ],
    "userPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CURSOR_PLUGIN_ROOT}/hooks/stn-prompt-router\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "preToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CURSOR_PLUGIN_ROOT}/hooks/stn-skill-gate\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CURSOR_PLUGIN_ROOT}/hooks/stn-state-validator\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CURSOR_PLUGIN_ROOT}/hooks/stn-routing-guard\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CURSOR_PLUGIN_ROOT}/hooks/stn-scope-guard\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CURSOR_PLUGIN_ROOT}/hooks/stn-circuit-breaker\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
