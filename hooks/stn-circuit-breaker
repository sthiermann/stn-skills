#!/usr/bin/env bash
# stn-circuit-breaker: PreToolUse hook for Edit/Write/Agent
# Blocks code modifications when circuit breaker is RED.
# Part of stn-skills hook system.
set -o pipefail
source "$(dirname "$0")/stn-hook-output"

# Kill-switch
[[ "${STN_SKILLS_HOOKS_DISABLE:-}" == "1" ]] && _allow

# Read stdin JSON
INPUT="$(cat)"
TOOL_NAME="$(printf '%s' "$INPUT" | json_get "tool_name" -)"

# Only gate code modification tools
case "$TOOL_NAME" in
  Edit|Write|Agent) ;;
  *) _allow ;;
esac

# Find execution state file
STATE_FILE=""
for dir in ".claude" "$(git rev-parse --show-toplevel 2>/dev/null)/.claude"; do
  [[ -f "$dir/plan-execution-state.json" ]] && STATE_FILE="$dir/plan-execution-state.json" && break
done

[[ -z "$STATE_FILE" ]] && _allow

# Read circuit breaker state (default GREEN when missing)
CB_STATE="$(json_get "circuit_breaker.state" "$STATE_FILE")"
[[ -z "$CB_STATE" ]] && CB_STATE="GREEN"

if [[ "$CB_STATE" == "RED" ]]; then
  FAILURES="$(json_get "circuit_breaker.consecutive_review_failures" "$STATE_FILE")"
  [[ -z "$FAILURES" ]] && FAILURES="0"
  _deny "Circuit breaker RED: ${FAILURES} consecutive failures. Review execution state before continuing."
fi

_allow
