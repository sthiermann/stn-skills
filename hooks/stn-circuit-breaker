#!/usr/bin/env bash
# stn-circuit-breaker: PreToolUse hook for Edit/Write/Agent
# Blocks code modifications when circuit breaker is RED.
# Part of stn-skills hook system.
set -o pipefail
source "$(dirname "$0")/stn-hook-output"

# Kill-switch
[[ "${STN_SKILLS_HOOKS_DISABLE:-}" == "1" ]] && _allow

# Read stdin JSON
INPUT="$(cat)"
TOOL_NAME="$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null || echo "")"

# Only gate code modification tools
case "$TOOL_NAME" in
  Edit|Write|Agent) ;;
  *) _allow ;;
esac

# Find execution state file
STATE_FILE=""
for dir in ".claude" "$(git rev-parse --show-toplevel 2>/dev/null)/.claude"; do
  [[ -f "$dir/plan-execution-state.json" ]] && STATE_FILE="$dir/plan-execution-state.json" && break
done

[[ -z "$STATE_FILE" ]] && _allow

# Read circuit breaker state
CB_STATE="$(jq -r '.circuit_breaker.state // "GREEN"' "$STATE_FILE" 2>/dev/null \
  || python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('circuit_breaker',{}).get('state','GREEN'))" "$STATE_FILE" 2>/dev/null \
  || echo "GREEN")"

if [[ "$CB_STATE" == "RED" ]]; then
  FAILURES="$(jq -r '.circuit_breaker.consecutive_review_failures // 0' "$STATE_FILE" 2>/dev/null \
    || python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('circuit_breaker',{}).get('consecutive_review_failures',0))" "$STATE_FILE" 2>/dev/null \
    || echo "0")"
  _deny "Circuit breaker RED: ${FAILURES} consecutive failures. Review execution state before continuing."
fi

_allow
