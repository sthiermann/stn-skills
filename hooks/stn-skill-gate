#!/usr/bin/env bash
# stn-skill-gate: PreToolUse hook for Skill invocations
# Blocks skill chain violations based on pipeline state.
# Part of stn-skills Layered Defense Enforcement.
set -eo pipefail
source "$(dirname "$0")/stn-hook-output"

# Kill-switch
[[ "${STN_SKILLS_HOOKS_DISABLE:-}" == "1" ]] && _allow

# Read stdin JSON
INPUT="$(cat)"
TOOL_NAME="$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null \
  || echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('tool_name',''))" 2>/dev/null \
  || echo "")"

# Only gate Skill tool calls
[[ "$TOOL_NAME" != "Skill" ]] && _allow

INVOKED_SKILL="$(echo "$INPUT" | jq -r '.tool_input.skill // empty' 2>/dev/null \
  || echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('tool_input',{}).get('skill',''))" 2>/dev/null \
  || echo "")"

# Only gate stn-skills invocations
[[ "$INVOKED_SKILL" != stn-skills:* ]] && _allow

# Find state file
STATE_FILE=""
for dir in ".claude" "$(git rev-parse --show-toplevel 2>/dev/null)/.claude"; do
  [[ -f "$dir/stn-skills-pipeline-state.json" ]] && STATE_FILE="$dir/stn-skills-pipeline-state.json" && break
done

# No state file = no pipeline active = allow
[[ -z "$STATE_FILE" ]] && _allow

# Read state via jq (python3 fallback)
ACTIVE_SKILL="$(jq -r '.active_skill // empty' "$STATE_FILE" 2>/dev/null || echo "")"
HANDOFF_VALIDATED="$(jq -r '.handoff_validated // false' "$STATE_FILE" 2>/dev/null || echo "false")"

# Extract short skill name
SHORT_SKILL="${INVOKED_SKILL#stn-skills:}"

# Non-chain skills: always allow
case "$SHORT_SKILL" in
  session-init|build-feature|pipeline-handoff-validator|codebase-audit|codebase-quality-bootstrap)
    _allow ;;
esac

# Chain enforcement: brainstorming -> plan-writing -> plan-execution
if [[ "$ACTIVE_SKILL" == "brainstorming" && "$SHORT_SKILL" == "plan-writing" ]]; then
  if [[ "$HANDOFF_VALIDATED" != "true" ]]; then
    _deny "Pipeline gate: handoff_validated is false. Run pipeline-handoff-validator on the design spec before invoking plan-writing."
  fi
elif [[ "$ACTIVE_SKILL" == "plan-writing" && "$SHORT_SKILL" == "plan-execution" ]]; then
  if [[ "$HANDOFF_VALIDATED" != "true" ]]; then
    _deny "Pipeline gate: handoff_validated is false. Run pipeline-handoff-validator on the plan before invoking plan-execution."
  fi
fi

_allow
