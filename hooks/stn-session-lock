#!/usr/bin/env bash
# stn-session-lock: SessionStart hook
# Prevents concurrent stn-skills sessions via mkdir lock.
# Part of stn-skills v5.0.0 Layered Defense Enforcement.
set -eo pipefail

# Hook output helper (Claude Code hookSpecificOutput format)
_deny() { local r="${1//\\/\\\\}"; r="${r//\"/\\\"}"; r="${r//$'\n'/\\n}"; printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","permissionDecision":"deny","permissionDecisionReason":"%s"}}' "$r"; exit 0; }

# Kill-switch
[[ "${STN_SKILLS_HOOKS_DISABLE:-}" == "1" ]] && exit 0

# Find repo root
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
LOCK_DIR="${REPO_ROOT}/.claude/stn-skills.lock"
PID_FILE="${LOCK_DIR}/pid"

# Check existing lock
if [[ -d "$LOCK_DIR" ]] && [[ -f "$PID_FILE" ]]; then
  LOCKED_PID="$(cat "$PID_FILE" 2>/dev/null || echo "")"
  if [[ "$LOCKED_PID" =~ ^[0-9]+$ ]] && kill -0 "$LOCKED_PID" 2>/dev/null; then
    _deny "Another stn-skills session is active (PID ${LOCKED_PID}). Close it first or delete .claude/stn-skills.lock/"
  fi
  # Stale lock — process dead, clean up
  rm -f "$PID_FILE" 2>/dev/null
  rmdir "$LOCK_DIR" 2>/dev/null || true
fi

# Create lock (mkdir without -p is atomic on POSIX — exactly one process succeeds)
mkdir -p "$(dirname "$LOCK_DIR")" 2>/dev/null || true
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  # Another session acquired the lock between our check and our attempt
  exit 0
fi
echo "$$" > "$PID_FILE"

exit 0
