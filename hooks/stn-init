#!/usr/bin/env bash
# stn-skills SessionStart hook
# Reads pipeline state + session-init skill, injects into session context.
# Uses jq for JSON parsing with python3 fallback. <50ms target.

set -eo pipefail

# Kill-switch: skip all stn-skills hooks
[[ "${STN_SKILLS_HOOKS_DISABLE:-}" == "1" ]] && exit 0

# JSON field reader: jq with python3 fallback
json_get() {
  local file="$1" field="$2"
  jq -r ".$field // empty" "$file" 2>/dev/null \
    || python3 -c "import json,sys; v=json.load(open(sys.argv[1])).get(sys.argv[2],''); print(v if not isinstance(v,list) else json.dumps(v))" "$file" "$field" 2>/dev/null \
    || echo ""
}

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# --- Read the session-init skill content ---
skill_file="${PLUGIN_ROOT}/skills/session-init/SKILL.md"
if [ ! -f "$skill_file" ]; then
  exit 0
fi
skill_content=$(cat "$skill_file" 2>/dev/null) || exit 0

# --- Locate pipeline state file ---
# Check cwd first (fast), fall back to git root if needed
state_file=""
if [ -f ".claude/stn-skills-pipeline-state.json" ]; then
  state_file=".claude/stn-skills-pipeline-state.json"
else
  git_root=$(git rev-parse --show-toplevel 2>/dev/null) || true
  if [ -n "$git_root" ] && [ -f "${git_root}/.claude/stn-skills-pipeline-state.json" ]; then
    state_file="${git_root}/.claude/stn-skills-pipeline-state.json"
  fi
fi

# --- Parse pipeline state (if found) ---
state_block=""
if [ -n "$state_file" ]; then
  # Validate file is readable and non-empty
  if [ ! -s "$state_file" ]; then
    state_file=""
  fi
fi

if [ -n "$state_file" ]; then
  # JSON field extraction via jq (python3 fallback)
  active_skill=$(json_get "$state_file" "active_skill")
  current_phase=$(json_get "$state_file" "current_phase")
  total_phases=$(json_get "$state_file" "total_phases")
  gates_passed=$(json_get "$state_file" "gates_passed")
  updated_at=$(json_get "$state_file" "updated_at")
  artifact_path=$(json_get "$state_file" "artifact_path")

  # Only build state block if essential fields are present
  if [ -n "$active_skill" ] && [ -n "$current_phase" ]; then
    # Staleness detection: warn if state is older than 24 hours
    stale_warning=""
    if [ -n "$updated_at" ]; then
      # Compare file modification time (more reliable than parsing ISO dates in bash)
      file_age_seconds=$(( $(date +%s) - $(stat -f %m "$state_file" 2>/dev/null || stat -c %Y "$state_file" 2>/dev/null || echo "0") ))
      if [ "$file_age_seconds" -gt 86400 ]; then
        days_old=$(( file_age_seconds / 86400 ))
        stale_warning="- **Warning:** State file is ${days_old} day(s) old. The pipeline may have been abandoned."
      fi
    fi

    # Artifact existence check
    artifact_warning=""
    if [ -n "$artifact_path" ] && [ "$artifact_path" != "null" ]; then
      artifact_resolve=""
      [ -f "$artifact_path" ] && artifact_resolve="$artifact_path"
      [ -z "$artifact_resolve" ] && [ -n "${git_root:-}" ] && [ -f "${git_root}/${artifact_path}" ] && artifact_resolve="${git_root}/${artifact_path}"
      if [ -z "$artifact_resolve" ]; then
        artifact_warning="- **Warning:** artifact_path \`${artifact_path}\` does not exist. The artifact may have been deleted."
      fi
    fi

    state_block=$(printf '%s\n' \
      "" \
      "---" \
      "" \
      "## Active Pipeline State" \
      "" \
      "**${active_skill}** | Phase ${current_phase}/${total_phases:-?} | Gates ${gates_passed:-[]} | ${updated_at:-unknown}" \
      ${stale_warning:+"$stale_warning"} \
      ${artifact_warning:+"$artifact_warning"} \
      "" \
      "**Resume:** Invoke \`Skill(skill: \"stn-skills:${active_skill}\")\` now."
    )
  fi
fi

# --- Combine skill content + optional state ---
full_content="${skill_content}"
if [ -n "$state_block" ]; then
  full_content="${skill_content}${state_block}"
fi

# --- Escape for JSON embedding ---
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\x08'/\\b}"
  s="${s//$'\x0c'/\\f}"
  printf '%s' "$s"
}

escaped=$(escape_for_json "$full_content")

# --- Platform-specific JSON output ---
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$escaped"
fi

exit 0
