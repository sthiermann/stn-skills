#!/usr/bin/env bash
# stn-routing-guard: PreToolUse hook for Edit/Write/Agent
# Denies first Agent dispatch outside active pipelines (forces routing check).
# Tracks multi-file edits and injects guidance at threshold.
# Part of stn-skills Layered Defense Enforcement.
set -o pipefail
source "$(dirname "$0")/stn-hook-output"

# Kill-switch (shared)
[[ "${STN_SKILLS_HOOKS_DISABLE:-}" == "1" ]] && _allow

# Dedicated kill-switch
[[ "${STN_ROUTING_GUARD_SKIP:-}" == "1" ]] && _allow

# Read stdin JSON
INPUT="$(cat)"
TOOL_NAME="$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null || echo "")"

# Only gate Edit/Write/Agent
case "$TOOL_NAME" in
  Edit|Write|Agent) ;;
  *) _allow ;;
esac

# For Agent calls: use a synthetic tracker entry (no file path)
if [[ "$TOOL_NAME" == "Agent" ]]; then
  FILE_PATH="__agent_dispatch__"
else
  FILE_PATH="$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null || echo "")"
  [[ -z "$FILE_PATH" ]] && _allow
fi

# Always allow .claude/ writes (state files, plans, tracker)
[[ "$FILE_PATH" != "__agent_dispatch__" ]] && [[ "$FILE_PATH" == */.claude/* || "$FILE_PATH" == .claude/* ]] && _allow

# Find repo root
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Check for active pipeline — if pipeline exists, defer to scope-guard
for dir in ".claude" "${REPO_ROOT}/.claude"; do
  if [[ -f "$dir/stn-skills-pipeline-state.json" ]]; then
    SKILL="$(jq -r '.active_skill // empty' "$dir/stn-skills-pipeline-state.json" 2>/dev/null || echo "")"
    PHASE="$(jq -r '.current_phase // 0' "$dir/stn-skills-pipeline-state.json" 2>/dev/null || echo "0")"
    TOTAL="$(jq -r '.total_phases // 0' "$dir/stn-skills-pipeline-state.json" 2>/dev/null || echo "0")"
    # Ensure numeric (non-numeric jq output → default to 0)
    [[ "${PHASE:-0}" =~ ^[0-9]+$ ]] || PHASE=0
    [[ "${TOTAL:-0}" =~ ^[0-9]+$ ]] || TOTAL=0
    if [[ -n "$SKILL" ]]; then
      # Treat completed pipeline (phase > total) as inactive
      if [[ "$SKILL" == "plan-execution" && "$PHASE" -gt 0 && "$TOTAL" -gt 0 && "$PHASE" -gt "$TOTAL" ]]; then
        break
      fi
      _allow
    fi
  fi
done

# Check for active task scope (codebase-audit quick fixes)
for dir in ".claude" "${REPO_ROOT}/.claude"; do
  [[ -f "$dir/current-task-scope.json" ]] && _allow
done

# --- No active pipeline. Deny first Agent dispatch (routing gate). ---
if [[ "$TOOL_NAME" == "Agent" ]]; then
  ROUTING_ACKED="${REPO_ROOT}/.claude/stn-routing-acked"
  if [[ ! -f "$ROUTING_ACKED" ]]; then
    mkdir -p "$(dirname "$ROUTING_ACKED")"
    date +%s > "$ROUTING_ACKED"
    _deny "No stn-skills pipeline active. For multi-file or design tasks, invoke Skill(skill: \"stn-skills:build-feature\") or Skill(skill: \"stn-skills:brainstorming\") first. For simple questions, retry Agent." \
      "ROUTING REQUIRED: Invoke the matching skill from the session-init routing table BEFORE dispatching agents. This deny will not repeat if you retry."
  else
    NOW="$(date +%s)"
    ACK_MTIME="$(stat -f %m "$ROUTING_ACKED" 2>/dev/null || stat -c %Y "$ROUTING_ACKED" 2>/dev/null || echo "0")"
    ACK_AGE="$((NOW - ACK_MTIME))"
    if [[ "$ACK_AGE" -gt 43200 ]]; then
      date +%s > "$ROUTING_ACKED"
      _deny "No stn-skills pipeline active (stale ack). Invoke matching skill first or retry Agent."
    fi
  fi
fi

# --- Track edits. ---
TRACKER="${REPO_ROOT}/.claude/stn-edit-tracker.json"
THRESHOLD="${STN_ROUTING_GUARD_THRESHOLD:-3}"

# Normalize file path to relative
REL_PATH="${FILE_PATH#"${REPO_ROOT}"/}"

# Block path traversal
[[ "$REL_PATH" == *../* || "$REL_PATH" == ..* ]] && _deny "Path traversal detected."

# Read or initialize tracker
TRACKED_FILES="[]"
if [[ -f "$TRACKER" ]]; then
  NOW="$(date +%s)"
  FILE_MTIME="$(stat -f %m "$TRACKER" 2>/dev/null || stat -c %Y "$TRACKER" 2>/dev/null || echo "0")"
  FILE_AGE="$((NOW - FILE_MTIME))"
  if [[ "$FILE_AGE" -le 43200 ]]; then
    TRACKED_FILES="$(jq -r '.files // []' "$TRACKER" 2>/dev/null || echo "[]")"
  fi
fi

# Re-edits to already-tracked files don't count again (skip dedup for Agent dispatches)
if [[ "$TOOL_NAME" != "Agent" ]]; then
  ALREADY="$(echo "$TRACKED_FILES" | jq --arg f "$REL_PATH" '[.[] | select(. == $f)] | length' 2>/dev/null || echo "0")"
  if [[ "${ALREADY:-0}" -gt 0 ]]; then
    _allow
  fi
fi

# Add file and check count
NEW_FILES="$(echo "$TRACKED_FILES" | jq --arg f "$REL_PATH" '. + [$f]' 2>/dev/null)" \
  || NEW_FILES="[\"$(_json_escape "$REL_PATH")\"]"
COUNT="$(echo "$NEW_FILES" | jq 'length' 2>/dev/null || echo "0")"

# Update tracker before threshold check — _inform() exits, so tracker must persist first
mkdir -p "$(dirname "$TRACKER")"
printf '{"files":%s}\n' "$NEW_FILES" > "$TRACKER"

if [[ "${COUNT:-0}" -ge "${THRESHOLD:-3}" ]]; then
  _inform "You have edited ${COUNT} files without an active pipeline. For multi-file changes, invoke Skill(skill: \"stn-skills:build-feature\") to start a structured pipeline. The stn-prompt-router will remind you at the start of each turn."
fi

_allow
