#!/usr/bin/env bash
# stn-hook-output: Shared output helpers for stn-skills hooks.
# Provides _allow(), _deny(), and _json_escape().
# Sourced by all hooks — do not execute directly.

_json_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  s="${s//$'\x08'/\\b}"
  s="${s//$'\x0c'/\\f}"
  printf '%s' "$s"
}

_allow() {
  echo '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"allow"}}'
  exit 0
}

# Usage: _deny "reason" ["additionalContext"]
_deny() {
  local reason
  reason="$(_json_escape "$1")"
  if [[ -n "${2:-}" ]]; then
    local ctx
    ctx="$(_json_escape "$2")"
    printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"%s","additionalContext":"%s"}}' "$reason" "$ctx"
  else
    printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"%s"}}' "$reason"
  fi
  exit 0
}
