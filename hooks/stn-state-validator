#!/usr/bin/env bash
# stn-state-validator: PreToolUse hook for Write tool
# Validates JSON content when writing to pipeline state files.
# Part of stn-skills v5.0.0 Layered Defense Enforcement.
set -eo pipefail

# Hook output helpers (Claude Code hookSpecificOutput format)
_allow() { echo '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"allow"}}'; exit 0; }
_deny() { local r="${1//\\/\\\\}"; r="${r//\"/\\\"}"; r="${r//$'\n'/\\n}"; printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"%s"}}' "$r"; exit 0; }

# Kill-switch
[[ "${STN_SKILLS_HOOKS_DISABLE:-}" == "1" ]] && _allow

# Read stdin JSON
INPUT="$(cat)"
TOOL_NAME="$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null || echo "")"

[[ "$TOOL_NAME" != "Write" ]] && _allow

FILE_PATH="$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null || echo "")"

# Only validate state files
case "$FILE_PATH" in
  *stn-skills-pipeline-state.json|*plan-execution-state.json) ;;
  *) _allow ;;
esac

# Validate the NEW content (not existing file — allows repair writes)
CONTENT="$(echo "$INPUT" | jq -r '.tool_input.content // empty' 2>/dev/null || echo "")"

if [[ -z "$CONTENT" ]]; then
  _deny "State file write has empty content."
fi

# Validate JSON syntax
if ! echo "$CONTENT" | jq empty 2>/dev/null && ! echo "$CONTENT" | python3 -c "import json,sys; json.load(sys.stdin)" 2>/dev/null; then
  _deny "State file content is not valid JSON. Fix the JSON before writing."
fi

# Validate required fields for pipeline state
if [[ "$FILE_PATH" == *pipeline-state* ]]; then
  MISSING=""
  for field in pipeline_id active_skill current_phase total_phases gates_passed updated_at; do
    HAS="$(echo "$CONTENT" | jq "has(\"$field\")" 2>/dev/null \
      || echo "$CONTENT" | python3 -c "import json,sys; print('true' if sys.argv[1] in json.load(sys.stdin) else 'false')" "$field" 2>/dev/null \
      || echo "false")"
    [[ "$HAS" != "true" ]] && MISSING="${MISSING} ${field}"
  done
  if [[ -n "$MISSING" ]]; then
    _deny "Pipeline state missing required fields:${MISSING}"
  fi
fi

_allow
