#!/usr/bin/env bash
# stn-state-validator: PreToolUse hook for Write tool
# Validates JSON content when writing to pipeline state files.
# Part of stn-skills hook system.
set -o pipefail
source "$(dirname "$0")/stn-hook-output"

# Kill-switch
[[ "${STN_SKILLS_HOOKS_DISABLE:-}" == "1" ]] && _allow

# Read stdin JSON
INPUT="$(cat)"
TOOL_NAME="$(printf '%s' "$INPUT" | json_get "tool_name" -)"

[[ "$TOOL_NAME" != "Write" ]] && _allow

FILE_PATH="$(printf '%s' "$INPUT" | json_get "tool_input.file_path" -)"

# Block path traversal
[[ "$FILE_PATH" == *../* || "$FILE_PATH" == ..* ]] && _deny "Path traversal detected in file path."

# Only validate state files
case "$FILE_PATH" in
  *stn-skills-pipeline-state.json|*plan-execution-state.json) ;;
  *) _allow ;;
esac

# Validate the NEW content (not existing file — allows repair writes)
CONTENT="$(printf '%s' "$INPUT" | json_get "tool_input.content" -)"

if [[ -z "$CONTENT" ]]; then
  _deny "State file write has empty content."
fi

# Validate JSON syntax (jq empty or python3 parse — specialized check, not a field read)
if ! printf '%s' "$CONTENT" | jq empty 2>/dev/null && ! printf '%s' "$CONTENT" | python3 -c "import json,sys; json.load(sys.stdin)" 2>/dev/null; then
  _deny "State file content is not valid JSON. Fix the JSON before writing."
fi

# Validate required fields for pipeline state
if [[ "$FILE_PATH" == *pipeline-state* ]]; then
  MISSING=""
  for field in pipeline_id active_skill current_phase total_phases gates_passed updated_at; do
    # has() is a specialized jq predicate (not a field read); python3 fallback checks dict membership
    HAS="$(printf '%s' "$CONTENT" | jq "has(\"$field\")" 2>/dev/null \
      || printf '%s' "$CONTENT" | python3 -c "import json,sys; print('true' if sys.argv[1] in json.load(sys.stdin) else 'false')" "$field" 2>/dev/null \
      || echo "false")"
    [[ "$HAS" != "true" ]] && MISSING="${MISSING} ${field}"
  done
  if [[ -n "$MISSING" ]]; then
    _deny "Pipeline state missing required fields:${MISSING}"
  fi
fi

_allow
